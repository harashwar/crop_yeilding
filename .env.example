# .env.example  -  Copy this file to .env and fill in your key
# ─────────────────────────────────────────────────────────────

# OpenWeatherMap API Key (Free tier — sign up at openweathermap.org)
# If left blank the app falls back to Open-Meteo (no humidity shown).
OWM_API_KEY=your_openweathermap_api_key_here
